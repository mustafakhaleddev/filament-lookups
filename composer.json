{
    "name": "wezlo/filament-lookups",
    "description": "Hierarchical Lookup Management for Filament with multi-tenant support",
    "keywords": [
        "laravel",
        "filament",
        "lookups",
        "hierarchical",
        "categories",
        "multi-tenant"
    ],
    "license": "MIT",
    "version": "1.0.0",
    "type": "library",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-livewire": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Wezlo\\FilamentLookups\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wezlo\\FilamentLookups\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wezlo\\FilamentLookups\\FilamentLookupsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
